# Application
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017,localhost:27018,localhost:27019/pharmacy-pos?replicaSet=rs0

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Or use a managed TLS Redis URL, e.g. Upstash
# REDIS_URL=rediss://default:<token>@<host>:6379
# KV_URL=rediss://default:<token>@<host>:6379
# KV_REST_API_URL=https://<host>
# KV_REST_API_TOKEN=<token>
# KV_REST_API_READ_ONLY_TOKEN=<read-only-token>

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# WebSocket
WEBSOCKET_PORT=3001

# Payment Gateways (Optional)
OPAY_API_KEY=
OPAY_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173

# Cloudinary (cloud storage for uploaded PO files)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Gemini AI (document processing - optional, falls back to regex)
GEMINI_API_KEY=your_gemini_api_key

# Email Configuration
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
EMAIL_FROM_NAME=Pharmacy POS
EMAIL_FROM_EMAIL=noreply@pharmacy.com
