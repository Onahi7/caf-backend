# ─── CAF Backend Environment Variables ──────────────────────────────────────
# Copy this file to `.env` and fill in real values for your deployment.

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/caf-pos

# ── Redis (used by Bull queues, rate limiting) ───────────────────────────────
# Local dev:
REDIS_URL=redis://localhost:6379
# Production (Upstash example — use the connection string from Upstash console,
# always starts with `rediss://` for TLS):
# REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=change-me-in-production
# Access token lifetime — set to 15m for sliding 14h session (refresh default 14h)
JWT_EXPIRATION=14h

# ── WebAuthn / FIDO2 ────────────────────────────────────────────────────────
# RP = Relying Party = your server.
# For LOCAL DEV, leave as "localhost" (WebAuthn works over http://localhost).
# For PRODUCTION, set this to the registered domain users sign in from
# (e.g. "carefam.sl" or "app.carefam.com") and ensure HTTPS is enabled.
# This value MUST match the origin the frontend is served from.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=CareFAM POS

# ── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CareFAM POS" <no-reply@carefam.sl>

# ── Africa's Talking (SMS — for OTP) ─────────────────────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=CareFAM

# ── CORS / Frontend origin ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Heroku deployment (when applicable) ─────────────────────────────────────
# Set automatically by Heroku. Don't override in production.
# DATABASE_URL=
